# ============================================================
# 2. ENHANCED FACE LOADING (Jittering enabled)
# ============================================================

@st.cache_resource
def load_known_faces():
    """Study photos intensely to create a better mathematical map."""
    known_encodings = []
    known_names = []
    
    valid_ext = ('.jpeg', '.jpg', '.png', '.jfif')
    files = [f for f in os.listdir(ME_FOLDER) if f.lower().endswith(valid_ext)]
    
    if not files:
        return [], []

    for filename in files:
        img_path = os.path.join(ME_FOLDER, filename)
        img = face_recognition.load_image_file(img_path)
        
        # num_jitters=10 makes the loading MUCH more accurate for laptop webcams
        encs = face_recognition.face_encodings(img, num_jitters=10, model="large")
        if len(encs) > 0:
            known_encodings.append(encs[0])
            # Cleans 'momen_one.jpg' -> 'Momen'
            name = re.sub(r'[\d_]+$', '', os.path.splitext(filename)[0]).replace('_', ' ').capitalize()
            known_names.append(name.split()[0]) # Just take the first word 'Momen'
                
    return known_encodings, known_names

# ============================================================
# 3. IDENTIFICATION LOGIC (Tolerance 0.7)
# ============================================================

def identify_person(frame, box, known_encs, known_names):
    x1, y1, x2, y2 = box
    h, w = frame.shape[:2]
    # Small padding helps the recognizer see your whole face structure
    y1, y2 = max(0, y1-15), min(h, y2+15)
    x1, x2 = max(0, x1-15), min(w, x2+15)
    
    face_img = frame[y1:y2, x1:x2]
    if face_img.size == 0: return "Unknown Person"

    try:
        # Re-detect face location within the YOLO box for precision
        face_locations = face_recognition.face_locations(face_img)
        if not face_locations:
            return "Unknown Person"

        # Compare with known signatures
        face_encs = face_recognition.face_encodings(face_img, face_locations)

        for face_encoding in face_encs:
            distances = face_recognition.face_distance(known_encs, face_encoding)
            if len(distances) > 0:
                best_match_idx = np.argmin(distances)
                # 0.7 Tolerance for maximum flexibility with lighting
                if distances[best_match_idx] < 0.7:
                    return known_names[best_match_idx]
                
    except Exception:
        pass
    return "Unknown Person"

