# 4. TELEGRAM & ALERT SYSTEM (Direct API Call)
# ============================================================

def send_telegram_direct(img_path, identity):
    url = f"https://api.telegram.org/bot{TOKEN}/sendPhoto"
    caption = f"🚨 {identity} detected!\nTime: {datetime.now().strftime('%H:%M:%S')}"
    try:
        with open(img_path, 'rb') as photo:
            requests.post(url, data={'chat_id': CHAT_ID, 'caption': caption}, files={'photo': photo})
    except Exception as e:
        print(f"Telegram Connection Error: {e}")

def trigger_alert(frame, identity):
    now = datetime.now().timestamp()
    # 30-second cooldown per person
    if identity not in st.session_state.last_alert or now - st.session_state.last_alert[identity] > 30:
        timestamp = datetime.now().strftime('%H%M%S')
        img_path = os.path.join("detections", f"{identity}_{timestamp}.jpg")
        cv2.imwrite(img_path, cv2.cvtColor(frame, cv2.COLOR_RGB2BGR))
        
        with open("database/detections.csv", "a", newline="") as f:
            csv.writer(f).writerow([datetime.now().strftime("%Y-%m-%d"), datetime.now().strftime("%H:%M:%S"), identity])
        
        threading.Thread(target=send_telegram_direct, args=(img_path, identity)).start()
        st.session_state.last_alert[identity] = now

