yolo_model = YOLO("models/yolov8m.pt")
known_encs, known_names = load_known_faces()

if 'last_alert' not in st.session_state: 
    st.session_state.last_alert = {}

col_feed, col_info = st.columns([3, 1])

with col_feed:
    active = st.toggle("Activate Surveillance")
    video_placeholder = st.image([])
    
    if active:
        cam = cv2.VideoCapture(0)
        while active:
            success, frame = cam.read()
            if not success: break
            
            frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            results = yolo_model.track(frame_rgb, persist=True, verbose=False)
            
            for r in results:
                if r.boxes:
                    for box in r.boxes:
                        if yolo_model.names[int(box.cls[0])] == "person" and float(box.conf[0]) > 0.5:
                            x1, y1, x2, y2 = map(int, box.xyxy[0])
                            
                            identity = identify_person(frame_rgb, [x1, y1, x2, y2], known_encs, known_names)
                            
                            color = (0, 255, 0) if identity != "Unknown Person" else (255, 0, 0)
                            cv2.rectangle(frame_rgb, (x1, y1), (x2, y2), color, 2)
                            cv2.putText(frame_rgb, f"{identity}", (x1, y1-10), 
                                        cv2.FONT_HERSHEY_SIMPLEX, 0.7, color, 2)
                            
                            trigger_alert(frame_rgb, identity)
            
            video_placeholder.image(frame_rgb)
        cam.release()

